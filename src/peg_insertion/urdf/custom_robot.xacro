<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro" name="ur5_shadow_peg">

  <xacro:arg name="name" default="ur"/>
  <xacro:arg name="ur_type" default="ur5e"/>
  <xacro:arg name="tf_prefix" default=""/>

  <!-- Import the UR macro -->
  <xacro:include filename="$(find ur_description)/urdf/ur_macro.xacro"/>

  <!-- Base link fixed to the world -->
  <link name="world"/>

  <!-- UR5e arm -->
  <xacro:ur_robot
    name="$(arg name)"
    tf_prefix="$(arg tf_prefix)"
    parent="world"
    joint_limits_parameters_file="$(find ur_description)/config/$(arg ur_type)/joint_limits.yaml"
    kinematics_parameters_file="$(find ur_description)/config/$(arg ur_type)/default_kinematics.yaml"
    physical_parameters_file="$(find ur_description)/config/$(arg ur_type)/physical_parameters.yaml"
    visual_parameters_file="$(find ur_description)/config/$(arg ur_type)/visual_parameters.yaml"
    force_abs_paths="true"
  >
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </xacro:ur_robot>

  <!-- ==================== ros2_control for Gazebo Sim ==================== -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- UR5e arm joints (6 DOF) -->
    <joint name="shoulder_pan_joint">
      <command_interface name="position"><param name="min">-6.28</param><param name="max">6.28</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="shoulder_lift_joint">
      <command_interface name="position"><param name="min">-6.28</param><param name="max">6.28</param></command_interface>
      <state_interface name="position"><param name="initial_value">-1.5708</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="elbow_joint">
      <command_interface name="position"><param name="min">-3.14</param><param name="max">3.14</param></command_interface>
      <state_interface name="position"><param name="initial_value">1.5708</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wrist_1_joint">
      <command_interface name="position"><param name="min">-6.28</param><param name="max">6.28</param></command_interface>
      <state_interface name="position"><param name="initial_value">-1.5708</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wrist_2_joint">
      <command_interface name="position"><param name="min">-6.28</param><param name="max">6.28</param></command_interface>
      <state_interface name="position"><param name="initial_value">-1.5708</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="wrist_3_joint">
      <command_interface name="position"><param name="min">-6.28</param><param name="max">6.28</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Shadow Hand finger joints — full 22 DOF (4 per FF/MF/RF, 5 for LF, 5 for TH) -->
    <!-- Index finger: spread(J4), MCP(J3), PIP(J2), DIP(J1) -->
    <joint name="FFJ4">
      <command_interface name="position"><param name="min">-0.436</param><param name="max">0.436</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FFJ3">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FFJ2">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="FFJ1">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <!-- Middle finger: spread(J4), MCP(J3), PIP(J2), DIP(J1) -->
    <joint name="MFJ4">
      <command_interface name="position"><param name="min">-0.436</param><param name="max">0.436</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="MFJ3">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="MFJ2">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="MFJ1">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <!-- Ring finger: spread(J4), MCP(J3), PIP(J2), DIP(J1) -->
    <joint name="RFJ4">
      <command_interface name="position"><param name="min">-0.436</param><param name="max">0.436</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RFJ3">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RFJ2">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="RFJ1">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <!-- Little finger: metacarpal(J5), spread(J4), MCP(J3), PIP(J2), DIP(J1) -->
    <joint name="LFJ5">
      <command_interface name="position"><param name="min">0</param><param name="max">0.698</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="LFJ4">
      <command_interface name="position"><param name="min">-0.436</param><param name="max">0.436</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="LFJ3">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="LFJ2">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="LFJ1">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <!-- Thumb: rotation(J5), abduct(J4), flex1(J3), flex2(J2), tip(J1) -->
    <joint name="THJ5">
      <command_interface name="position"><param name="min">-1.047</param><param name="max">1.047</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="THJ4">
      <command_interface name="position"><param name="min">0</param><param name="max">1.309</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="THJ3">
      <command_interface name="position"><param name="min">-0.262</param><param name="max">0.262</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="THJ2">
      <command_interface name="position"><param name="min">-0.524</param><param name="max">0.524</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
    <joint name="THJ1">
      <command_interface name="position"><param name="min">0</param><param name="max">1.571</param></command_interface>
      <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- gz_ros2_control Gazebo system plugin -->
  <gazebo>
    <plugin filename="libgz_ros2_control-system.so"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find peg_insertion)/config/controllers.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Shadow hand -->
  <xacro:include filename="$(find peg_insertion)/urdf/shadow_hand.urdf.xacro"/>

  <!-- Attach shadow hand wrist to UR5e tool flange -->
  <joint name="wrist_to_hand" type="fixed">
    <parent link="tool0"/>
    <child link="forearm"/>
    <origin xyz="0 0 0" rpy="0 1.5708 0"/>
  </joint>

  <!-- High friction on finger links for reliable grasping -->
  <gazebo reference="ffproximal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="ffmiddle"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="ffdistal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="mfproximal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="mfmiddle"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="mfdistal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="rfproximal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="rfmiddle"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="rfdistal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="lfproximal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="lfmiddle"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="lfdistal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="thdistal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="thmiddle"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="thproximal"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>
  <gazebo reference="palm"><mu1>5.0</mu1><mu2>5.0</mu2></gazebo>

</robot>
